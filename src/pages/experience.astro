---
import { Icon } from "astro-icon/components";
import { experiences } from "../data/experienceData";

const accents = [
  "from-emerald-400 via-green-300 to-lime-300",
  "from-amber-400 via-yellow-300 to-orange-300",
  "from-rose-400 via-pink-300 to-red-300",
  "from-indigo-400 via-blue-300 to-cyan-300",
  "from-purple-400 via-violet-300 to-fuchsia-300",
];
---

<h1 class="text-xl lg:text-3xl font-bold my-4">Experience</h1>

<div class="my-4 sm:my-6 lg:my-8">
  <div class="flex flex-col gap-6">
    {
      experiences.map((exp, index) => {
        const accent = accents[index % accents.length];

        return (
          <div class="relative pl-4">
            <div
              class={`absolute left-0 top-2 bottom-2 w-[2px] bg-gradient-to-br ${accent}`}
            />

            <div class="group relative rounded-xl border border-black/10 bg-[#fffaf0]/80 p-4 sm:p-5 lg:p-6 shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden">
              <div
                class={`absolute inset-0 bg-gradient-to-br ${accent} blur-2xl opacity-5 pointer-events-none`}
              />

              <div class="flex flex-col gap-2 sm:flex-row sm:justify-between sm:items-start mb-3 sm:mb-4 relative z-10">
                <div>
                  <p class="text-base sm:text-lg font-semibold">{exp.title}</p>
                  <p class="text-sm text-black/50 mt-1">{exp.period}</p>
                </div>

                <div class="sm:text-right">
                  <p class="font-medium">{exp.company}</p>
                  <p class="text-sm text-black/50">{exp.location}</p>
                </div>
              </div>

              <div class="mb-3 sm:mb-4 flex flex-wrap gap-1.5 sm:gap-2 relative z-10">
                {exp.skillIcons.map((icon) => (
                  <div class="flex items-center justify-center px-2.5 sm:px-3 py-1 rounded-full bg-black/[0.05] border border-black/[0.08]">
                    <Icon name={icon} size={16} />
                  </div>
                ))}
              </div>

              <ul class="text-sm sm:text-base text-black/70 flex flex-col gap-1.5 sm:gap-2 relative z-10">
                {exp.description.map((point) => (
                  <li class="flex gap-2">
                    <span class="mt-1.5 w-1 h-1 rounded-full bg-black/40" />
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        );
      })
    }
  </div>
</div>
