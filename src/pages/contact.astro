---
import { Icon } from "astro-icon/components";

const accents = [
  "from-amber-400 via-yellow-300 to-orange-300",
  "from-indigo-400 via-blue-300 to-cyan-300",
];
---

<section class="max-w-4xl py-10 sm:py-12">
  <h2 class="text-xl lg:text-3xl font-bold mb-8 sm:mb-10">Get in Touch</h2>

  <div class="grid gap-8 sm:gap-10 lg:grid-cols-2 items-start">
    <div class="space-y-5 sm:space-y-6">
      <h3 class="text-xs font-semibold uppercase tracking-widest text-black/40">
        Direct Channels
      </h3>

      <nav class="flex flex-col border-t border-black/5">
        {
          [
            {
              href: "mailto:krishnanand2517@gmail.com",
              label: "Email",
              icon: "mdi:email",
            },
            {
              href: "https://github.com/Krishnanand2517",
              label: "GitHub",
              icon: "mdi:github",
            },
            {
              href: "https://www.linkedin.com/in/krishnanandyadav",
              label: "LinkedIn",
              icon: "mdi:linkedin",
            },
          ].map((link) => (
            <a
              href={link.href}
              target="_blank"
              class="group flex items-center justify-between py-3 sm:py-4 border-b border-black/5 hover:bg-black/[0.02] transition-colors px-1"
            >
              <div class="flex items-center gap-3 sm:gap-4">
                <Icon
                  name={link.icon}
                  size={20}
                  class="text-black/70 group-hover:text-black transition-colors"
                />
                <span class="text-sm sm:text-base font-medium text-black/70 group-hover:text-black">
                  {link.label}
                </span>
              </div>
              <Icon
                name="mdi:arrow-top-right"
                size={16}
                class="text-black/20 group-hover:text-black group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all"
              />
            </a>
          ))
        }
      </nav>
    </div>

    <div class="space-y-6 sm:space-y-8">
      <div class="space-y-3 sm:space-y-4">
        <h3
          class="text-xs font-semibold uppercase tracking-widest text-black/40"
        >
          Independent Projects
        </h3>

        <a
          href="https://krishnanand.itch.io"
          target="_blank"
          class="group relative block p-4 sm:p-5 rounded-xl border border-black/10 bg-[#fffaf0]/80 shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden"
        >
          <div
            class={`absolute inset-0 opacity-0 group-hover:opacity-10 transition duration-500 bg-gradient-to-br ${accents[0]} blur-2xl opacity-5 pointer-events-none`}
          >
          </div>

          <div class="flex items-center gap-3 sm:gap-4 mb-2 relative z-10">
            <Icon name="cib:itch-io" size={22} />
            <span class="font-semibold text-base sm:text-lg text-black/80">
              itch.io Store
            </span>
          </div>

          <p class="text-sm text-black/50 leading-relaxed relative z-10">
            Check out the experimental games and prototypes I've built.
          </p>
        </a>
      </div>

      <div class="space-y-3 sm:space-y-4">
        <h3
          class="text-xs font-semibold uppercase tracking-widest text-black/40"
        >
          Writing
        </h3>

        <a
          href="https://krishnanand.hashnode.dev"
          target="_blank"
          class="group relative block p-4 sm:p-5 rounded-xl border border-black/10 bg-[#fffaf0]/80 shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden"
        >
          <div
            class={`absolute inset-0 opacity-0 group-hover:opacity-10 transition duration-500 bg-gradient-to-br ${accents[1]} blur-2xl opacity-5 pointer-events-none`}
          >
          </div>

          <div class="flex items-center gap-3 sm:gap-4 mb-2 relative z-10">
            <Icon name="simple-icons:hashnode" size={22} />
            <span class="font-semibold text-base sm:text-lg text-black/80">
              Bits & Bytes
            </span>
          </div>

          <p class="text-sm text-black/50 leading-relaxed relative z-10">
            Technical deep-dives and musings on software development.
          </p>
        </a>
      </div>
    </div>
  </div>
</section>
