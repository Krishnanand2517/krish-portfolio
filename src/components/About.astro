---
import { Icon } from "astro-icon/components";

import { skillsData } from "../data/skillsData";
---

<h1 class="text-xl lg:text-3xl font-bold my-4">About Me</h1>
<p class="text-sm lg:text-base">
  I'm a software engineer based in India who genuinely enjoys building clean,
  user-friendly, and well-crafted products. I enjoy solving real problems with
  simple, maintainable solutions. When I'm not working, I'm usually reading,
  writing, planning trips, or experimenting with new ideas in code.
</p>

<div class="my-12">
  <div class="flex flex-col gap-10">
    {
      Object.entries(skillsData).map(([category, items]) => (
        <div class="w-full flex flex-col gap-6 items-start">
          <h3 class="w-full lg:w-auto lg:text-lg font-bold">{category}</h3>
          <div class="lg:ml-6 flex flex-wrap items-center gap-3">
            {items.map((skill) => (
              <div class="inline-flex items-center gap-2 px-4 py-2 bg-amber-100/80 border border-dashed border-zinc-700 rounded-lg hover:scale-95 transition-all">
                <Icon name={skill.icon} size={20} />
                <span class="text-sm font-medium">{skill.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</div>

<div class="my-8 border border-black/15 rounded-xl overflow-hidden">
  <button
    id="edu-btn"
    onclick="const open = this.getAttribute('aria-expanded') === 'true'; this.setAttribute('aria-expanded', !open); document.getElementById('edu-content').classList.toggle('hidden', open); document.getElementById('edu-chev').classList.toggle('rotate-180', !open);"
    aria-expanded="false"
    class="w-full flex items-center justify-between px-4 py-3 hover:bg-black/5 transition-colors"
  >
    <span class="text-sm font-medium">Education</span>
    <svg
      id="edu-chev"
      class="w-4 h-4 text-black/40 transition-transform duration-200"
      viewBox="0 0 16 16"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M4 6l4 4 4-4"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </button>

  <div id="edu-content" class="hidden border-t border-black/15">
    <div class="flex justify-between items-center px-4 py-3 text-sm gap-4">
      <div>
        <p class="font-medium">Integrated M.Sc. Computer Science</p>
        <p class="text-xs text-black/50 mt-0.5">Oct 2021 – May 2026</p>
      </div>
      <div class="text-right">
        <p class="font-medium">Pondicherry University</p>
        <p class="text-xs text-black/50 mt-0.5">Puducherry, India</p>
      </div>
    </div>
    <div
      class="flex justify-between items-center px-4 py-3 text-sm gap-4 border-t border-black/15"
    >
      <div>
        <p class="font-medium">Higher Secondary (Class XII)</p>
        <p class="text-xs text-black/50 mt-0.5">Apr 2020 – May 2021</p>
      </div>
      <div class="text-right">
        <p class="font-medium">Jawahar Navodaya Vidyalaya</p>
        <p class="text-xs text-black/50 mt-0.5">West Bengal, India</p>
      </div>
    </div>
  </div>
</div>
