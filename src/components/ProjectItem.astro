---
import { Icon } from "astro-icon/components";

interface Project {
  name: string;
  descriptionPoints: string[];
  skillIcons: string[];
  liveLink: string;
  code: string;
  image: string;
}

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;

const accents = [
  "from-emerald-400 via-green-300 to-lime-300",
  "from-rose-400 via-pink-300 to-red-300",
  "from-indigo-400 via-blue-300 to-cyan-300",
  "from-purple-400 via-violet-300 to-fuchsia-300",
  "from-amber-400 via-yellow-300 to-orange-300",
  "from-gray-400 via-amber-100 to-orange-300",
];
const accent = accents[index % accents.length];
---

<div
  class="group relative rounded-xl border border-black/10 bg-[#fffaf0]/80 p-4 sm:p-5 lg:p-6 shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden"
>
  <div class={`absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r ${accent}`}>
  </div>

  <div
    class={`absolute inset-0 opacity-0 group-hover:opacity-10 transition duration-500 bg-gradient-to-br ${accent} blur-2xl opacity-5 pointer-events-none`}
  >
  </div>

  <div class="relative z-10 mb-3 sm:mb-4 overflow-hidden rounded-lg">
    <img
      src=`/project-imgs/${project.image}`
      alt={project.name}
      class="w-full h-40 sm:h-48 object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
    />
  </div>

  <h2
    class="text-base sm:text-lg lg:text-2xl font-semibold mb-1 sm:mb-2 tracking-tight relative z-10"
  >
    {project.name}
  </h2>

  <p
    class="text-sm sm:text-base text-black/60 mb-3 sm:mb-4 leading-relaxed relative z-10"
  >
    {project.descriptionPoints[0]}
  </p>

  <div class="mb-3 sm:mb-4 flex flex-wrap gap-1.5 sm:gap-2 relative z-10">
    {
      project.skillIcons.map((icon) => (
        <div class="flex items-center justify-center px-2.5 sm:px-3 py-1 rounded-full bg-black/[0.05] border border-black/[0.08]">
          <Icon name={icon} size={16} />
        </div>
      ))
    }
  </div>

  {
    project.descriptionPoints.length > 1 && (
      <ul class="mb-4 sm:mb-5 text-sm sm:text-base text-black/70 flex flex-col gap-1.5 sm:gap-2 relative z-10">
        {project.descriptionPoints.slice(1).map((point) => (
          <li class="flex gap-2">
            <span class="mt-1.5 w-1 h-1 rounded-full bg-black/40" />
            <span>{point}</span>
          </li>
        ))}
      </ul>
    )
  }

  <div
    class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3 pt-2 relative z-10"
  >
    <a
      href={project.liveLink}
      target="_blank"
      class="inline-flex justify-center items-center gap-1.5 px-4 py-2 text-sm rounded-full bg-black text-white hover:bg-black/80 transition-all duration-300"
    >
      <Icon name="mdi:link" size={16} />
      <span>{project.name === "WarTime Game" ? "Play Game" : "Live"}</span>
    </a>

    <a
      href={project.code}
      target="_blank"
      class="inline-flex justify-center items-center gap-1.5 px-4 py-2 text-sm rounded-full border border-black/20 hover:bg-black/5 transition-all duration-300"
    >
      <Icon
        name={project.name === "WarTime Game" ? "mdi:video" : "mdi:code-braces"}
        size={16}
      />
      <span>{project.name === "WarTime Game" ? "Video" : "Code"}</span>
    </a>
  </div>
</div>
